# Azure AI Foundry
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>

# Azure Service Principal (para Databricks)
AZURE_CLIENT_ID=<app-id>
AZURE_CLIENT_SECRET=<secret>
AZURE_TENANT_ID=<tenant-id>

# Databricks
DATABRICKS_HOST=https://adb-<workspace-id>.azuredatabricks.net
DATABRICKS_WAREHOUSE_ID=<warehouse-id>
DATABRICKS_CATALOG=apex_dq_premium
DATABRICKS_SCHEMA=pedido_sugerido

# Telegram Bot
TELEGRAM_BOT_TOKEN=<token-from-botfather>

# Admin
ADMIN_PASSWORD=<admin-password>
MAXI_AGENT_ID=<agent-id>
